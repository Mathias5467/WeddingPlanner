{
  "name": "nasa-svadba-planner",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dist": "next build && electron-builder"
  },
  "build": {
    "appId": "com.mojasvadba.planner",
    "productName": "Naša Svadba",
    "directories": {
        "output": "dist"
    },
    "win": {
        "target": "nsis",
        "icon": "public/logo.ico" 
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": "always",
        "createStartMenuShortcut": true,
        "shortcutName": "Naša Svadba",
        "installerIcon": "public/logo.ico",
        "uninstallerIcon": "public/logo.ico"
    }
    },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}